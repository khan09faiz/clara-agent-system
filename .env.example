# Clara Agent System — Environment Configuration
# Copy this file to .env and fill in your values

# LLM Backend: rule_based (default), groq, or ollama
LLM_BACKEND=rule_based

# Groq API key (free tier: https://console.groq.com)
GROQ_API_KEY=

# Ollama settings (for local LLM)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# OpenAI Whisper key (for audio transcription)
WHISPER_API_KEY=

# n8n credentials (for docker-compose)
N8N_USER=admin
N8N_PASSWORD=changeme
